{
  "name": "allied-kcc",
  "version": "0.6.0",
  "description": "Allied KCC — farmer-first composite KCC (allied activities) + Pashu Suraksha insurance + Aanchal co-op wedge. Extracted from FarmerPay.",
  "main": "backend/src/app.js",
  "scripts": {
    "start": "node backend/src/app.js",
    "dev": "nodemon backend/src/app.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint backend/src/ --ext .js",
    "lint:fix": "eslint backend/src/ --ext .js --fix"
  },
  "keywords": [
    "allied-kcc",
    "kcc",
    "dairy",
    "livestock-insurance",
    "nlm",
    "cooperative",
    "india"
  ],
  "author": "Allied KCC Team",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.3",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "rate-limit-redis": "^4.2.0",
    "sequelize": "^6.37.3",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }

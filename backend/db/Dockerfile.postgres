# Allied KCC dev database image.
# Base: official PostGIS image (Debian + PGDG apt repo already configured).
# Adds: pgvector (postgresql-16-pgvector from PGDG) so a single container
# provides Postgres 16 + PostGIS + pgvector — the blueprint's DB stack.
FROM postgis/postgis:16-3.4

RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-16-pgvector \
    && rm -rf /var/lib/apt/lists/*

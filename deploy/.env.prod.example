# ── Production environment for the VPS ──────────────────────────────────────
# Copy this to  deploy/.env  and replace every CHANGE_ME with a real value.
# Generate strong secrets with:  openssl rand -hex 32
# NEVER commit the real deploy/.env (it is git-ignored).

NODE_ENV=production
PORT=3000
APP_NAME=Allied KCC
APP_URL=https://api.farmerpay.ai
API_PREFIX=/api/v1

# ── Database (the values below are also used to create the Postgres container) ─
DB_NAME=allied_kcc
DB_USER=allied_kcc
DB_PASSWORD=CHANGE_ME_db_password
DB_DIALECT=postgres
# DB_HOST / DB_PORT are set automatically by docker-compose (postgres:5432)

# ── Messaging / cache ─────────────────────────────────────────────────────────
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password
# REDIS_HOST / RABBITMQ_URL are set automatically by docker-compose

# ── Auth secrets (MUST change — run: openssl rand -hex 32) ────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret
JWT_ISSUER=farmerpay-platform

# ── ERP integration (start in filedrop mode for the first society) ────────────
INTEGRATION_MODE=filedrop

# ── SMS (leave as-is for a CLOSED pilot with pre-created accounts). ───────────
# For public signups, set a real provider (msg91 / gupshup / twilio) + keys.
SMS_PROVIDER=twilio
# SMS_API_KEY=
# SMS_API_SECRET=

# ── File storage: for a pilot the app writes to the mounted disk volume.
# Add S3 (Indian region) later for durability.

# ============================================================
# Allied KCC — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- Application ----
NODE_ENV=development
PORT=3000
APP_NAME=Allied KCC
APP_URL=http://localhost:3000
API_PREFIX=/api/v1

# ---- PostgreSQL 16 (+ pgvector + PostGIS) ----
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=allied_kcc_dev
DB_USER=allied_kcc
DB_PASSWORD=allied_kcc
DB_DIALECT=postgres
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_LOGGING=true

# Read replica (production only — leave blank for dev)
DB_READ_HOST=
DB_READ_PORT=5432
DB_READ_USER=
DB_READ_PASSWORD=

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=akcc:
REDIS_DEFAULT_TTL=3600

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://allied_kcc:allied_kcc@127.0.0.1:5672
RABBITMQ_EXCHANGE=allied_kcc_exchange
RABBITMQ_PREFETCH=10

# ---- JWT Authentication (MPIN + OTP only — no passwords) ----
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=allied-kcc

# ---- OTP Configuration ----
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_OTP_MAX=5

# ---- Encryption Keys (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ----
AADHAAR_ENCRYPTION_KEY=your_64_char_hex_key_here
BANK_ENCRYPTION_KEY=your_64_char_hex_key_here

# ---- Aanchal ERP Adapter (THE WEDGE) ----
# Sync mode is switchable per capability: live | webhook | filedrop | mock
# filedrop is the degraded launch mode — daily CSV/XLSX batches over SFTP.
INTEGRATION_MODE=mock
ERP_FILEDROP_INBOX=./data/erp/inbox
ERP_FILEDROP_OUTBOX=./data/erp/outbox
ERP_FILEDROP_ARCHIVE=./data/erp/archive
ERP_LIVE_BASE_URL=
ERP_LIVE_API_KEY=
ERP_WEBHOOK_SECRET=

# ---- Finacle (bank prefill + reconciliation) ----
FINACLE_WEBHOOK_SECRET=your_finacle_webhook_hmac_secret_here

# ---- AWS General ----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ---- S3-compatible object storage (Indian region — evidence data lake) ----
S3_BUCKET_NAME=allied-kcc-uploads
S3_BUCKET_REGION=ap-south-1
S3_PRESIGNED_URL_EXPIRY=3600
S3_MAX_FILE_SIZE=10485760

# ---- AWS KMS ----
KMS_KEY_ID=your_kms_key_id
KMS_REGION=ap-south-1

# ---- Email ----
EMAIL_PROVIDER=ses
SES_REGION=ap-south-1
EMAIL_FROM=noreply@allied-kcc.in
EMAIL_FROM_NAME=Allied KCC
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# ---- SMS Gateway ----
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_SENDER_ID=AKCCIN

# ---- Bhashini (speech + translation; Bhashini-first, IndicWhisper fallback) ----
BHASHINI_API_URL=https://meity-auth.ulcacontrib.org
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_DEFAULT_LANG=hi
BHASHINI_SUPPORTED_LANGS=hi,en

# ---- AI services (Python FastAPI: vision/ speech/ predict/ rag/) ----
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=your_ai_api_key

# ---- Feature Flags ----
FEATURE_SMS_NOTIFICATIONS=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_PUSH_NOTIFICATIONS=false

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Logging ----
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
